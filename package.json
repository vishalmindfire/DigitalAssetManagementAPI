{
  "name": "digitalassetmanagementapi",
  "version": "1.0.0",
  "description": "REST API for file upload system with filter and search",
  "homepage": "https://github.com/vishalmindfire/DigitalAssetManagementAPI#readme",
  "bugs": {
    "url": "https://github.com/vishalmindfire/DigitalAssetManagementAPI/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vishalmindfire/DigitalAssetManagementAPI.git"
  },
  "license": "MIT",
  "author": "Vishal Minz",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "tsx --watch --env-file .env.development src/index.ts",
    "dev:staging": "tsx --watch --env-file .env.staging src/index.ts",
    "dev:prod": "tsx --watch --env-file .env.production src/index.ts",
    "start": "node --env-file .env.production dist/src/index.js",
    "build": "tsc -p tsconfig.prod.json",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.3.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.2.1",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-perfectionist": "^5.9.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "imports": {
    "#*": {
      "development": "./src/*",
      "types": "./src/*",
      "default": "./dist/src/*"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint",
      "prettier --check"
    ],
    "*.{json,yml,yaml,md}": [
      "prettier --check"
    ]
  }
}
